# Copy this file to .env and fill in real values.
# .env is gitignored. Only .env.example is committed.

# Firebase Web SDK config (EXPO_PUBLIC_ = inlined into app bundle at build time)
# Note: RNFB uses google-services.json / GoogleService-Info.plist for native mobile.
# These vars are for consistency and any JS-side Firebase usage.
# Get all Firebase values from Firebase Console -> Project settings -> General -> Your apps -> Web app -> SDK setup and configuration -> Config.
# If the project has no Web app yet, create one first so this config block is available.
# Firebase API key for the project web app config.
EXPO_PUBLIC_FIREBASE_API_KEY=
# Firebase Auth domain for the project, usually <project-id>.firebaseapp.com.
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# Firebase project identifier.
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# Firebase Storage bucket hostname for the project.
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# Firebase Cloud Messaging sender ID from the web app config.
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Firebase app ID for the registered Web app.
EXPO_PUBLIC_FIREBASE_APP_ID=
# Google Analytics measurement ID for the Web app.
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# RevenueCat (Phase 6 - separate keys for iOS and Android)
# RevenueCat public SDK key for the iOS app from RevenueCat -> Project settings -> Apps.
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
# RevenueCat public SDK key for the Android app from RevenueCat -> Project settings -> Apps.
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# Unity Ads (Phase 6 - Game IDs and placement IDs embedded in bundle)
# Unity Ads Game ID for the iOS app from the Unity Dashboard project settings.
EXPO_PUBLIC_UNITY_GAME_ID_IOS=
# Unity Ads Game ID for the Android app from the Unity Dashboard project settings.
EXPO_PUBLIC_UNITY_GAME_ID_ANDROID=
# Unity Ads rewarded placement ID configured in the Unity Dashboard.
EXPO_PUBLIC_UNITY_PLACEMENT_ID_REWARDED=
# Unity Ads interstitial placement ID configured in the Unity Dashboard.
EXPO_PUBLIC_UNITY_PLACEMENT_ID_INTERSTITIAL=
